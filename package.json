{
  "name": "@openclaw/claw-armor",
  "version": "1.0.0",
  "description": "混合驱动的新一代 Agent 安全插件 - 五层纵深防御 + 语义意图对齐",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublish": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "security",
    "agent",
    "prompt-injection",
    "intent-alignment",
    "defense-in-depth"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
